{
  "manifest_version": 3,
  "name": "APHELION",
  "description": "Hide unwanted texts and images with APHELION in seconds; Built for everyone!",
  "version": "1.0.0",
  "homepage_url": "https://fluffito.github.io/APHELIION/",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "APHELION"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "aphelion-censor-style.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
