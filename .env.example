# APHELION Stripe + site config
PUBLIC_SITE_URL=https://fluffito.github.io/
CORS_ORIGIN=*

# Stripe secrets
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
